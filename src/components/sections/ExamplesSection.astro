---
import { getUI, tokenize } from "~/i18n";
import { DEFAULT_LOCALE } from "~/i18n/locales";

interface Props {
  lang?: string;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = getUI(lang).examples;

// Emoji stay in code; the question text comes from the dictionary by index.
const emojis = ["🥗", "🩺", "❤️", "📅", "🥦", "📚"];
const examples = emojis.map((emoji, i) => ({ emoji, text: t.questions[i] }));

// description contains a {kbd}Enter{/kbd} chip — render via tokens, no raw HTML.
const descSegments = tokenize(t.description);
---

<section id="examples" class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-10 md:grid-cols-2 md:gap-14">
      <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-black/5">
        <video
          src="https://pub-4381eeaa2126408e92be4a3b3267fd55.r2.dev/examples.webm"
          poster="/marketing/examples.jpg"
          class="aspect-[16/10] w-full object-cover"
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          aria-label={t.videoAriaLabel}
        ></video>
      </div>
      <div>
        <h2 class="text-3xl font-bold text-df-text md:text-4xl">
          {t.headline}
        </h2>
        <p class="mt-4 text-lg text-gray-700">
          {
            descSegments.map((seg) =>
              seg.kind === "kbd" ? (
                <kbd class="rounded bg-gray-100 px-1.5 py-0.5 text-sm font-mono">{seg.value}</kbd>
              ) : seg.kind === "text" ? (
                seg.value
              ) : (
                <br />
              ),
            )
          }
        </p>
      </div>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        examples.map((q) => (
          <button
            type="button"
            class="example-card group rounded-2xl border border-gray-200 bg-white p-5 text-left transition hover:border-df-green-dark hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-df-green-dark"
            data-question={q.text}
          >
            <p class="flex items-start gap-2 text-base font-medium text-df-text group-hover:text-df-green-dark">
              <span aria-hidden="true" class="text-xl leading-none">
                {q.emoji}
              </span>
              <span>{q.text}</span>
            </p>
            <p class="mt-3 text-sm text-gray-500">{t.ctaHint}</p>
          </button>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { scrollToHeroChat } from "~/lib/scroll-to-hero";

  document.querySelectorAll<HTMLButtonElement>(".example-card").forEach(
    (btn) => {
      btn.addEventListener("click", () => {
        const question = btn.dataset.question;
        if (!question) return;
        scrollToHeroChat();
        window.dispatchEvent(
          new CustomEvent("drfuhrman:populateInput", {
            detail: { text: question },
          }),
        );
      });
    },
  );
</script>
