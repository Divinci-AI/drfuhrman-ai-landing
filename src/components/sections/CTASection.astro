---
import { getUI } from "~/i18n";
import { DEFAULT_LOCALE } from "~/i18n/locales";

interface Props {
  lang?: string;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = getUI(lang).cta;
---

<section class="bg-df-navy py-16">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-3xl font-bold text-white md:text-4xl">
      {t.headline}
    </h2>
    <p class="mt-4 text-lg text-white/80">
      {t.description}
    </p>
    <a
      href="#hero"
      data-focus-chat
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-df-green-leaf px-8 py-3 text-base font-semibold text-df-navy transition hover:bg-white hover:text-df-green-dark"
    >
      {t.buttonText}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
